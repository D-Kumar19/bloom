# Public site URL used in copied share links and Open Graph metadata.
# Required in production (e.g. https://bloom.app).
# Local dev: you can leave this set; share links still use localhost while
# you are on localhost, so new features are tested on your machine.
NEXT_PUBLIC_SITE_URL=https://bloom.app

# Bouquet counter persistence (required on Vercel; optional locally).
# Create a Vercel KV store and connect it to the project, or add Upstash Redis
# REST credentials. Without these, the counter only works on local file storage.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
